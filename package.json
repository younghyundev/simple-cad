{
  "name": "simple-cad",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:performance": "vite build --ssr src/cad/performance/performanceBaseline.ts --outDir .cad-performance --emptyOutDir && node .cad-performance/performanceBaseline.js",
    "test:conversion": "vite build --ssr src/cad/io/conversionRegressionCheck.ts --outDir .cad-conversion --emptyOutDir && node .cad-conversion/conversionRegressionCheck.js",
    "test:cad-fidelity": "vite build --ssr src/cad/io/roundTripCheck.ts --outDir .cad-fidelity --emptyOutDir && node .cad-fidelity/roundTripCheck.js",
    "verify": "npm run build && npm run test:cad-fidelity && npm run test:conversion && npm run test:performance && npm run test:e2e"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
